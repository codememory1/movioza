APP_ENV=dev
APP_SECRET=
APP_DEBUG=true
APP_SHARE_DIR=var/share

DEFAULT_URI=http://api.movioza.loc

DATABASE_HOST="postgres"
DATABASE_PORT=5432
DATABASE_USER="movioza"
DATABASE_PASSWORD="admin"
DATABASE_NAME="movioza"
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?serverVersion=16&charset=utf8"

REDIS_SCHEME="tcp"
REDIS_HOST="redis"
REDIS_PORT=6380
REDIS_PASSWORD="admin"
REDIS_DATABASE=1

S3_ACCESS_KEY="movioza"
S3_SECRET_KEY="movioza_password"
S3_VERSION="latest"
S3_REGION="us-east-1"
S3_ENDPOINT="http://minio:9000"
S3_USE_PATH_STYLE_ENDPOINT=true

BUNNY_DOMAIN="https://movioza-dev.b-cdn.net"
BUNNY_SECRET_KEY="secret"

# Aria2
ARIA2_HOST="http://aria2.movioza.loc"
ARIA2_PORT=6880
ARIA2_SECRET="movioza"
ARIA2_RPC_PORT=6800
